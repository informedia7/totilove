# Admin Server Environment Configuration

# Server Configuration
NODE_ENV=development
ADMIN_PORT=3003
ADMIN_HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=totilove1
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2

# PostgreSQL Tools Path (for backup/restore)
# Found at: C:\Program Files\PostgreSQL\17\bin
PG_BIN_PATH=C:\Program Files\PostgreSQL\17\bin

# Redis Configuration (optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session & Security
ADMIN_SESSION_SECRET=change_this_secret_key_in_production
JWT_SECRET=change_this_jwt_secret_in_production
ADMIN_SESSION_EXPIRY=86400000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# IP Whitelist (optional, comma-separated)
# ADMIN_IP_WHITELIST=127.0.0.1,::1